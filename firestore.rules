
/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model. All data is considered private and is
 * exclusively accessible to the user who created it. Access control is based on the user's authenticated UID.
 *
 * Data Structure: The data is organized hierarchically. All user-specific content, including family trees,
 * people, and relationships, is nested under a top-level `/users/{userId}` path. This structure inherently
 * links data to its owner, simplifying security logic.
 *
 * Key Security Decisions:
 * - User Isolation: Users can only read and write data within their own path (`/users/{their_own_userId}`). Cross-user access is strictly forbidden.
 * - No User Enumeration: Listing documents in the top-level `/users` collection is disallowed to protect user privacy.
 * - Default Deny: Any operation not explicitly granted by these rules is denied.
 *
 * Denormalization for Authorization: To ensure performant and secure access checks without costly `get()` calls,
 * key identifiers are denormalized down the data tree. For example, every document within a family tree (like a 'Person'
 * or 'Relationship') contains a `userId` and `treeId` field. The rules enforce that these denormalized fields are
 * correctly set on creation, guaranteeing data integrity.
 *
 * Structural Segregation: All data is private, so there is no need to segregate public and private content into
 * separate collections. The entire database follows a consistent, private-by-default model.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    /**
     * isSignedIn
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * isOwner
     * Checks if the authenticated user's UID matches the provided userId from the path.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * isRecoveryUser
     * TEMPORARY rule to allow a specific user email to access an orphaned user's data for recovery.
     */
    function isRecoveryUser(userId) {
      return userId == 'fsW3k9bT24XDIPHiuoL56U5zuKF3' && request.auth.token.email == 'yakiravidar@gmail.com';
    }


    /**
     * isExistingOwner
     * Combines owner check with an existence check for update/delete operations.
     * Prevents modifying or deleting a document that does not exist.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * hasValidCreateData_UserProfile
     * On UserProfile creation, ensures the document's internal `id` field
     * matches the user's auth UID and the document ID.
     */
    function hasValidCreateData_UserProfile(userId) {
      let data = request.resource.data;
      return data.id == userId;
    }

    /**
     * hasValidCreateData_FamilyTree
     * Validates that a new FamilyTree document has its `userId` field set
     * to the UID of the creating user.
     */
    function hasValidCreateData_FamilyTree(userId) {
      let data = request.resource.data;
      return data.userId == userId;
    }

    //-------------------------------------------------------------------------
    // Collection Rules
    //-------------------------------------------------------------------------

    /**
     * @description Controls access to a user's own profile document.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Explicitly deny listing the /users collection or any potential subcollections.
      allow create: if isOwner(userId) && hasValidCreateData_UserProfile(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isOwner(userId);

      /**
       * @description Controls access to a user's collection of family trees.
       * @path /users/{userId}/familyTrees/{treeId}
       */
      match /familyTrees/{treeId} {
        allow get: if isOwner(userId) || isRecoveryUser(userId) || (get(/databases/$(database)/documents/publicTrees/$(treeId)).data.id == treeId) || (exists(/databases/$(database)/documents/sharedTrees/$(treeId)) && get(/databases/$(database)/documents/sharedTrees/$(treeId)).data.sharedWithUserId == request.auth.uid);
        allow list: if isOwner(userId) || isRecoveryUser(userId);
        allow create: if isOwner(userId) && hasValidCreateData_FamilyTree(userId);
        allow update: if isExistingOwner(userId) || isRecoveryUser(userId);
        allow delete: if isOwner(userId) || isRecoveryUser(userId);

        /**
         * @description Controls access to individual person records within a family tree.
         * @path /users/{userId}/familyTrees/{treeId}/people/{personId}
         */
        match /people/{personId} {
          allow get, list: if isOwner(userId) || isRecoveryUser(userId) || (get(/databases/$(database)/documents/publicTrees/$(treeId)).data.id == treeId) || (exists(/databases/$(database)/documents/sharedTrees/$(treeId)) && get(/databases/$(database)/documents/sharedTrees/$(treeId)).data.sharedWithUserId == request.auth.uid);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.treeId == treeId;
          allow update: if isExistingOwner(userId) || isRecoveryUser(userId);
          allow delete: if isOwner(userId) || isRecoveryUser(userId);

          /**
           * @description Controls access to social links associated with a person.
           * @path /users/{userId}/familyTrees/{treeId}/people/{personId}/socialLinks/{socialLinkId}
           */
          match /socialLinks/{socialLinkId} {
            allow read: if isOwner(userId) || isRecoveryUser(userId) || (get(/databases/$(database)/documents/publicTrees/$(treeId)).data.id == treeId) || (exists(/databases/$(database)/documents/sharedTrees/$(treeId)) && get(/databases/$(database)/documents/sharedTrees/$(treeId)).data.sharedWithUserId == request.auth.uid);
            allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.treeId == treeId && request.resource.data.personId == personId;
            allow update: if isExistingOwner(userId) || isRecoveryUser(userId);
            allow delete: if isOwner(userId) || isRecoveryUser(userId);
          }
          
          match /gallery/{photoId} {
            allow read: if isOwner(userId) || isRecoveryUser(userId) || (get(/databases/$(database)/documents/publicTrees/$(treeId)).data.id == treeId) || (exists(/databases/$(database)/documents/sharedTrees/$(treeId)) && get(/databases/$(database)/documents/sharedTrees/$(treeId)).data.sharedWithUserId == request.auth.uid);
            allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.treeId == treeId && request.resource.data.personId == personId;
            allow delete: if isOwner(userId) || isRecoveryUser(userId);
          }
        }

        /**
         * @description Controls access to relationship records within a family tree.
         * @path /users/{userId}/familyTrees/{treeId}/relationships/{relationshipId}
         */
        match /relationships/{relationshipId} {
          allow get, list: if isOwner(userId) || isRecoveryUser(userId) || (get(/databases/$(database)/documents/publicTrees/$(treeId)).data.id == treeId) || (exists(/databases/$(database)/documents/sharedTrees/$(treeId)) && get(/databases/$(database)/documents/sharedTrees/$(treeId)).data.sharedWithUserId == request.auth.uid);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.treeId == treeId;
          allow update: if isExistingOwner(userId) || isRecoveryUser(userId);
          allow delete: if isOwner(userId) || isRecoveryUser(userId);
        }

        /**
         * @description Controls access to the canvas position data for people in a tree.
         * @path /users/{userId}/familyTrees/{treeId}/canvasPositions/{positionId}
         */
        match /canvasPositions/{positionId} {
          allow read: if isOwner(userId) || isRecoveryUser(userId) || (get(/databases/$(database)/documents/publicTrees/$(treeId)).data.id == treeId) || (exists(/databases/$(database)/documents/sharedTrees/$(treeId)) && get(/databases/$(database)/documents/sharedTrees/$(treeId)).data.sharedWithUserId == request.auth.uid);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.treeId == treeId;
          allow update: if isExistingOwner(userId) || isRecoveryUser(userId);
          allow delete: if isOwner(userId) || isRecoveryUser(userId);
        }
        
        /**
         * @description Controls access to user-created manual calendar events.
         * @path /users/{userId}/familyTrees/{treeId}/manualEvents/{eventId}
         */
        match /manualEvents/{eventId} {
          allow read: if isOwner(userId) || isRecoveryUser(userId) || (get(/databases/$(database)/documents/publicTrees/$(treeId)).data.id == treeId) || (exists(/databases/$(database)/documents/sharedTrees/$(treeId)) && get(/databases/$(database)/documents/sharedTrees/$(treeId)).data.sharedWithUserId == request.auth.uid);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.treeId == treeId;
          allow update: if isExistingOwner(userId) || isRecoveryUser(userId);
          allow delete: if isOwner(userId) || isRecoveryUser(userId);
        }

        match /rootsProjects/{projectId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
    
    match /userEmails/{email} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }
    
    /**
     * @description Controls access to metadata for exported files.
     * @path /exportedFiles/{fileId}
     */
    match /exportedFiles/{fileId} {
        allow read, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    match /sharedTrees/{shareId} {
      allow get: if isSignedIn() && (request.auth.uid == resource.data.ownerUserId || request.auth.uid == resource.data.sharedWithUserId);
      allow list: if isSignedIn(); // relies on client query with where() clause
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerUserId;
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.ownerUserId || request.auth.uid == resource.data.sharedWithUserId || isRecoveryUser(resource.data.ownerUserId));
    }

    match /publicTrees/{treeId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.ownerUserId == request.auth.uid || isRecoveryUser(resource.data.ownerUserId));
    }
    
    match /{path=**}/gallery/{photoId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /{path=**}/people/{personId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
  }
}
